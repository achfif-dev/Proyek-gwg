{
  "appId": "com.gwg.superapp",
  "appName": "GWG Super App",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com"]
    },
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
